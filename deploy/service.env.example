# Copy to /etc/paseo-downsizer/service.env  (root:root, chmod 600).
# This file holds the HOT PROXY KEY — never commit it, never world-readable.

# Chain endpoints
RELAY_WS=wss://paseo-rpc.n.dwellir.com
AH_WS=wss://asset-hub-paseo-rpc.n.dwellir.com

# ss58 of the sudo key the proxy acts for (public address — not a secret)
SUDO_ACCOUNT=<sudo-account-ss58>

# Bind the API to localhost only; Caddy proxies to it.
BIND_ADDR=127.0.0.1:8080

# Bearer token required for POST /api/control (pause/resume). Generate a long
# random value, e.g. `openssl rand -hex 32`. Read endpoints don't need it.
CONTROL_TOKEN=<random-64-hex>

# The proxy DELEGATE seed/mnemonic (a 12-word mnemonic is fine).
#   - LEAVE UNSET for monitor-only validation (service reads chain, never dispatches).
#   - SET IT ONLY AT GO-LIVE (Thu 2 Jul 2026, 12:00 CEST), then restart the service.
# PROXY_SURI=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
