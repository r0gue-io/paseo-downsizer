# URL of the Rust downsizer service (axum HTTP+JSON API).
NEXT_PUBLIC_SERVICE_URL=http://localhost:8080

# Optional block explorer base for tx-hash links in the dispatch log.
# The tx hash is appended to this base, e.g. https://paseo.subscan.io/extrinsic/
NEXT_PUBLIC_EXPLORER=

# --- Optional: treat the chain as source of truth via PAPI (polkadot-api) ---
# Set to "1" to let the UI read live counters directly from the relay + Asset Hub
# websockets instead of only /api/state. Requires `polkadot-api` installed.
NEXT_PUBLIC_USE_PAPI=0
NEXT_PUBLIC_RELAY_WS=wss://paseo-rpc.n.dwellir.com
NEXT_PUBLIC_AH_WS=wss://asset-hub-paseo-rpc.n.dwellir.com
